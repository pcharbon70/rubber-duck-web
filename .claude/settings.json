{
  "commitMessageRules": {
    "disallowedTerms": [
      "Claude",
      "claude",
      "AI",
      "ai",
      "artificial intelligence",
      "assisted",
      "generated",
      "Co-Authored-By: Claude",
      "anthropic",
      "🤖",
      "🦾",
      "🤯"
    ],
    "enforceHumanStyle": true,
    "noAIAttribution": true,
    "noAIEmojis": true
  },
  "gitRules": {
    "requireExplicitCommitCommand": true,
    "neverPush": true,
    "commitMessageFormat": "conventional"
  },
  "codeGenerationRules": {
    "alwaysResearchFirst": true,
    "followProjectPatterns": true,
    "noUnsolicited": true
  }
}